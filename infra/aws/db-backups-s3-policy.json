{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBackupPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::cerebro-amigo-db-backups",
      "Condition": { "StringLike": { "s3:prefix": ["postgres", "postgres/*"] } }
    },
    {
      "Sid": "RwBackupObjects",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::cerebro-amigo-db-backups/postgres/*"
    }
  ]
}
