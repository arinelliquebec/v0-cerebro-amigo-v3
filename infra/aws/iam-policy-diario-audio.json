{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TranscribeStartGet",
      "Effect": "Allow",
      "Action": [
        "transcribe:StartTranscriptionJob",
        "transcribe:GetTranscriptionJob"
      ],
      "Resource": "*"
    },
    {
      "Sid": "S3AudioBucket",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::cerebro-amigo-audio-sa-east-1/*"
    }
  ]
}
