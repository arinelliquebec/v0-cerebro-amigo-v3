{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CerebroContainerLogsAwslogsDriver",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:sa-east-1:004177894935:log-group:/cerebro/*"
    }
  ]
}
