# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
NOTIFIER_MODE=scheduled
SCHEDULER_INTERVAL_SECONDS=60

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://postgres:local@postgres:5432/cerebro

# ─── Auth interna ──────────────────────────────────────────────────────────
INTERNAL_API_TOKEN=troque-isto

# ─── VAPID ─────────────────────────────────────────────────────────────────
# Geradas uma única vez (https://web-push-codelab.glitch.me ou similar).
# Em produção, do Key Vault. Em dev, do .env (gitignored).
VAPID_PUBLIC_KEY=BPzG_dummy_public_key_substituir
VAPID_PRIVATE_KEY=ZpD_dummy_private_key_substituir
VAPID_SUBJECT=mailto:contato@cerebroamigo.com.br

# ─── Push delivery ──────────────────────────────────────────────────────────
PUSH_TTL_SECONDS=3600
PUSH_URGENCY=normal
