# ─── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL_HAIKU=claude-haiku-4-5
MODEL_SONNET=claude-sonnet-4-6

# ─── LangSmith (observabilidade LLM) ───────────────────────────────────────
# LGPD categoria especial → escolha:
#   1) LANGSMITH_HIDE_INPUTS=true + LANGSMITH_HIDE_OUTPUTS=true (só metadata)
#   2) LangSmith self-hosted (enterprise)
#   3) redação por callback (ver app/observability.py)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=cerebro-amigo-dev
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
PII_REDACTION_ENABLED=true

# ─── Postgres (mesma DB do gateway/backend .NET) ───────────────────────────
POSTGRES_DSN=postgresql://postgres:local@postgres:5432/cerebro

# ─── Auth interna ──────────────────────────────────────────────────────────
INTERNAL_API_TOKEN=troque-isto

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development         # development | staging | production
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
MAX_RETRY_AUDIT=2
SHADOW_MODE=false           # se true, processa mas NÃO finaliza (modo de validação)
