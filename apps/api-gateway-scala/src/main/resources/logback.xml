<?xml version="1.0" encoding="UTF-8"?>
<!-- Sem este arquivo, o logback assume root=DEBUG → o smoke em prod (ADR-067) mostrou
     o pool Hikari e o housekeeper inundando o log a cada 30s. root=INFO limpa o log. -->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Hikari/Ember são verbosos em DEBUG; mantém em INFO. -->
  <logger name="com.zaxxer.hikari" level="INFO"/>
  <logger name="org.http4s.ember" level="INFO"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
