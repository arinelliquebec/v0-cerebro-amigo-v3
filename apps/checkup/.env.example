# apps/checkup — variáveis de ambiente (triagem pública, :3001)

# Banco — schema `checkup` no RDS (mesmo DSN dos serviços, força SSL no client)
CHECKUP_DATABASE_URL=postgresql://user:pass@host:5432/cerebro_v3

# LLM — chave Anthropic PRÓPRIA do checkup (workspace/spend-limit separado da clínica)
ANTHROPIC_API_KEY=sk-ant-...

NEXT_PUBLIC_SITE_URL=https://checkup.cerebroamigo.com.br

# Cockpit de Aquisição (ADR-046/ADR-050) — Bearer aceito em /api/funnel-metrics.
# MESMO valor do CHECKUP_METRICS_TOKEN do web/BFF. Sem ele → 503 fail-closed
# (não expõe métricas de negócio nesta superfície pública).
CHECKUP_METRICS_TOKEN=

# Observabilidade: a definir (Datadog). Ver DEBT CK-1.
