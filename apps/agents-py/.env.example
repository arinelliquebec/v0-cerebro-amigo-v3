# ─── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL_HAIKU=claude-haiku-4-5
MODEL_SONNET=claude-sonnet-4-6

# ─── LangSmith ─────────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=cerebro-amigo-agents-dev
# Default do código é true (LGPD, DEBT T0-4) — sete =false só para depurar em dev.
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true
PII_REDACTION_ENABLED=true

# ─── Postgres (mesma DB) ───────────────────────────────────────────────────
POSTGRES_DSN=postgresql://postgres:local@postgres:5432/cerebro

# ─── Auth interna ──────────────────────────────────────────────────────────
INTERNAL_API_TOKEN=troque-isto

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Scheduling ─────────────────────────────────────────────────────────────
# Antecedência mínima/máxima (em minutos) para o resumidor disparar antes
# da consulta. Resumos só são gerados quando inicia_em ∈ [now+min, now+max].
RESUMIDOR_LEAD_MIN_MIN=30
RESUMIDOR_LEAD_MIN_MAX=120

# Intervalo do varredor (em segundos)
SCHEDULER_INTERVAL_SECONDS=300

# Gate de custo diário de LLM (ADR-011): teto em USD (timezone America/Sao_Paulo)
# que PAUSA agentes batch não-críticos. risco_silencioso é isento; o plano
# interativo (crise/conversa) nunca é gateado. Fail-open. <=0 desabilita.
# $5 é placeholder — calibrar com custo_usd real.
MAX_DAILY_LLM_USD=5.0

# Modo: 'scheduled' (default) roda APScheduler; 'manual' só expõe endpoints HTTP
AGENTS_MODE=scheduled
