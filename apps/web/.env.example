# URLs dos serviços (dev local — docker usa nomes dos containers)
API_GATEWAY_URL=http://localhost:5050

# Auth BFF
JWT_SECRET=
INTERNAL_API_TOKEN=

# Web Push (público — exposto ao browser)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cockpit de Aquisição (ADR-046/ADR-050) — BFF lê as métricas agregadas do Check-up.
# CHECKUP_METRICS_TOKEN = MESMO valor do apps/checkup. Sem ele → cockpit só clínico.
# Em prod (Vercel): vercel env add CHECKUP_METRICS_TOKEN production.
CHECKUP_METRICS_TOKEN=
CHECKUP_METRICS_URL=https://checkup.cerebroamigo.com.br/api/funnel-metrics
