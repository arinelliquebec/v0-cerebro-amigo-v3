# Cópia para .env e preencha. NUNCA commitar .env (está no .gitignore).
# Sem prefixo `export` em nenhuma linha — docker-compose env_file não interpreta.

# === Banco ===
# .NET gateway lê POSTGRES_DSN (formato Npgsql key-value).
POSTGRES_DSN=Host=HOST;Port=5432;Database=cerebro_v3;Username=USER;Password=PASS;SSL Mode=Require;Trust Server Certificate=true
POSTGRES_HOST=HOST
POSTGRES_PORT=5432
POSTGRES_DB=cerebro_v3
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASS
# Serviços Python (asyncpg/psycopg3) leem POSTGRES_DSN_URL (formato URL).
POSTGRES_DSN_URL=postgresql://USER:PASS@HOST:5432/cerebro_v3?sslmode=require

# === Auth ===
JWT_SECRET=change-me-min-32-chars
INTERNAL_API_TOKEN=change-me

# === Email (Resend) ===
RESEND_API_KEY=re_xxxx
EMAIL_FROM=Cérebro Amigo <onboarding@resend.dev>

# === CFM — Validação de CRM (Infosimples) ===
# Obter token em: https://infosimples.com/consultas/cfm-cadastro/
# false = bypass (dev sem token / emergência) — grava crm_situacao='NaoValidado'
INFOSIMPLES_TOKEN=
INFOSIMPLES_CFM_URL=https://api.infosimples.com/api/v2/consultas/cfm/cadastro
CRM_VALIDATION_ENABLED=true

# === MEMED (prescrição digital) ===
# Sandbox: chaves fixas de homologação do MEMED (área de parceiro/doc).
# Prod: chaves próprias após validação técnica do MEMED.
# Sem essas vars, os endpoints /api/v1/memed respondem erro claro (gateway sobe normal).
MEMED_API_KEY=
MEMED_SECRET_KEY=
MEMED_API_BASE=https://integrations.api.memed.com.br/v1
MEMED_SCRIPT_URL=https://integrations.memed.com.br/modulos/plataforma.sinapse-prescricao/build/sinapse-prescricao.min.js

# === Web Push (VAPID) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# === Cifragem em repouso (ADR-018) ===
# 32 bytes hex (64 chars). Gerar: openssl rand -hex 32
# Em dev pode ficar vazio (modo legacy). Em prod é obrigatória.
ENCRYPTION_KEY=

# === URLs dos serviços (dev local) ===
API_GATEWAY_URL=http://localhost:5050
ORCHESTRATOR_PY_URL=http://localhost:8081
AGENTS_PY_URL=http://localhost:8082
NOTIFIER_PY_URL=http://localhost:8083
FRONTEND_URL=http://localhost:3000
PORTAL_PACIENTE_URL=http://localhost:3000

# === Provider LLM (ADR-015 — provider-switchável) ===
# anthropic = API direta da Anthropic (default operacional AGORA). Desbloqueia
#   dev hoje, sem depender de quota/Marketplace/perfil Bedrock.
# bedrock   = AWS Bedrock (atrás da flag). Trocar para `bedrock` em produção
#   quando as quotas estiverem semeadas, ou para clientes que exijam AWS-only.
# Residência: os perfis Bedrock `global.` processam FORA do BR (sem perfil
#   in-region sa-east-1), então Anthropic API e Bedrock-global são equivalentes
#   em residência — o critério vira simplicidade (ver ADR-015).
LLM_PROVIDER=anthropic

# === Anthropic API (LLM_PROVIDER=anthropic) ===
# NUNCA commitar a key real. Em produção, injetar via secret manager / env.
ANTHROPIC_API_KEY=sk-.....
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8

# === AWS Bedrock (LLM_PROVIDER=bedrock — auth via IAM role, sem API key) ===
AWS_REGION=sa-east-1
BEDROCK_REGION=sa-east-1
# IDs = inference profiles (prefixo global.). On-demand puro (anthropic.*) dá
# ValidationException "model identifier is invalid" no Converse em sa-east-1.
BEDROCK_MODEL_HAIKU=global.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_SONNET=global.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_OPUS=global.anthropic.claude-opus-4-8
# Dev: usar AWS_PROFILE. Prod: IAM role da EC2 (sem credenciais aqui).
AWS_PROFILE=default

# === Embeddings / RAG (ADR-028) ===
# Embedding é SEMPRE Bedrock in-region (LGPD): cohere.embed-multilingual-v3 roda
# ON-DEMAND em sa-east-1 (1024-dim). NÃO usar cohere.embed-v4 — só existe via
# profile global.* (cross-region), conflita com a residência de dado. Em dev sem
# credenciais AWS, EMBEDDINGS_ENABLED=false desliga indexação/busca semântica.
EMBEDDINGS_ENABLED=true
BEDROCK_EMBED_MODEL=cohere.embed-multilingual-v3
RAG_TOP_K=8
RAG_INDEX_INTERVAL_HOURS=12

# === Diário de Voz (Amazon Transcribe + S3) ===
# Bucket deve existir em sa-east-1 antes de usar a feature. Perfil/role precisa
# de transcribe:StartTranscriptionJob, transcribe:GetTranscriptionJob e
# s3:PutObject/GetObject/DeleteObject no bucket
# (ver infra/aws/iam-policy-diario-audio.json).
S3_BUCKET_AUDIO=cerebro-amigo-audio-sa-east-1
TRANSCRIBE_POLL_INTERVAL_S=2.0
TRANSCRIBE_TIMEOUT_S=120.0

# === LangSmith (observabilidade IA) ===
LANGSMITH_API_KEY=lsv......
LANGSMITH_PROJECT=cerebro-amigo-v3
LANGSMITH_TRACING_V2=true
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
PII_REDACTION_ENABLED=true

# === Modos dos serviços ===
SHADOW_MODE=false
AGENTS_MODE=scheduled
NOTIFIER_MODE=scheduled
SCHEDULER_INTERVAL_SECONDS=60

# === Feature flags ===
HUMAN_IN_THE_LOOP=true
ENABLE_AUDIT_AGENT=true
MAX_DAILY_LLM_USD=5.00

# === Sentry (monitoramento e erros) ===
# Pegue o DSN em: sentry.io → Projects → Settings → Client Keys (DSN)
# Pegue org/project em: sentry.io → Settings → Organization / Project Settings
# Pegue o auth token em: sentry.io → Settings → Account → User Auth Tokens
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.us.sentry.io/xxxx
SENTRY_DSN=https://xxxx@xxxx.ingest.us.sentry.io/xxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_eyxxxxxxxx

# === Infra ===
# nome real da role IAM da EC2 (usado por scripts de deploy)
EC2_ROLE_NAME=cerebro-amigo-ec2-role

# === Teleconsulta — vídeo P2P (ADR-026) ===
# A mídia é P2P (E2E, DTLS-SRTP) e NÃO é gravada. A sinalização vive no gateway.
# O coturn (TURN) só entra quando o NAT bloqueia o P2P direto.
#
# Gateway — monta os iceServers devolvidos ao navegador:
STUN_URLS=stun:stun.l.google.com:19302
# Sem TURN_URLS/TURN_SECRET → só STUN (ok na maioria; falha atrás de CGNAT).
# Aponte p/ o coturn, ex.: turn:SEU_IP:3478?transport=udp,turn:SEU_IP:3478?transport=tcp
TURN_URLS=
TURN_SECRET=
TURN_TTL_SECONDS=3600
#
# coturn (serviço no docker-compose, profile "turn"). Em PROD, ative o profile
# e preencha o IP público. TURN_SECRET = MESMO valor acima (compartilhado).
# COMPOSE_PROFILES=turn
TURN_REALM=cerebro-amigo
TURN_EXTERNAL_IP=

MEMED_API_KEY=
MEMED_SECRET_KEY=
MEMED_API_BASE=https://integrations.api.memed.com.br/v1
MEMED_SCRIPT_URL=https://integrations.memed.com.br/modulos/plataforma.sinapse-prescricao/build/sinapse-prescricao.min.js
MEMED_API_URL=https://integrations.api.memed.com.br/v1