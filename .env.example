# === Banco ===
POSTGRES_DSN=postgresql://user:pass@localhost:5432/cerebro_amigo

# === Auth ===
JWT_SECRET=change-me-min-32-chars
INTERNAL_API_TOKEN=change-me

# === Email (Resend) ===
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@example.com

# === Web Push (VAPID) ===
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# === URLs dos serviços (dev local) ===
API_GATEWAY_URL=http://localhost:5050
ORCHESTRATOR_PY_URL=http://localhost:8081
AGENTS_PY_URL=http://localhost:8082
NOTIFIER_PY_URL=http://localhost:8083

# === AWS Bedrock (sem ANTHROPIC_API_KEY) ===
AWS_REGION=sa-east-1
BEDROCK_REGION=sa-east-1
BEDROCK_MODEL_HAIKU=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_SONNET=anthropic.claude-sonnet-4-6-20251001-v1:0
BEDROCK_MODEL_OPUS=anthropic.claude-opus-4-7-20251001-v1:0
# Dev: usar AWS_PROFILE. Prod: IAM role da EC2 (sem credenciais aqui).
AWS_PROFILE=default

# === LangSmith (observabilidade IA) ===
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cerebro-amigo-v3
LANGSMITH_TRACING_V2=true
PII_REDACTION_ENABLED=true

# === Modos dos serviços ===
SHADOW_MODE=false
AGENTS_MODE=enabled
NOTIFIER_MODE=enabled
SCHEDULER_INTERVAL_SECONDS=60
